# === 민감 정보 ===
.env
.env.*
*.key
*.pem
credentials.*
secrets.*

# === AI 도구 런타임 (동기화 불필요) ===
.omc/
.claude/cache/
.claude/debug/
.claude/downloads/
.claude/history.jsonl
.claude/todos/
.claude/transcripts/

# === 프로젝트별 sync 복사본 (원본: _shared/) ===
# sync-tools.cmd 실행으로 복원 가능 → GitHub에 중복 저장 불필요
projects/*/.claude/skills/
projects/*/.claude/agents/
projects/*/.claude/commands/
projects/*/.agent/skills/
projects/*/.agent/workflows/

# === 워크스페이스 루트 .claude (프로젝트 레벨 아닌 것) ===
.claude/

# === OS/에디터 ===
.DS_Store
Thumbs.db
desktop.ini
*.swp
*~

# === 임시 파일 ===
*.tmp
*.bak
*.log
node_modules/
__pycache__/
.next/
.vercel/

