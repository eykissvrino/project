+      groupedByCompany[company].count++;
+
+      const amount = result.sucsfbidAmt
+        ? parseInt(result.sucsfbidAmt.replace(/[^\d]/g, "")) || 0
+        : 0;
+      groupedByCompany[company].winAmount += amount;
