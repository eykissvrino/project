+      const resultDate = new Date(result.createdAt);
+      if (resultDate > groupedByCompany[company].lastDate) {
+        groupedByCompany[company].lastDate = resultDate;
+      }
+    });
+
+    const recentCompanies = Object.entries(groupedByCompany)
+      .map(([name, data]) => ({
