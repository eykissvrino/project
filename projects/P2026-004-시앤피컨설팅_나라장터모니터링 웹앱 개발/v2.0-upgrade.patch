+      allTimeTopCompanies: companies,
+      recentPeriodCompanies: recentCompanies,
+    });
+  } catch (error) {
+    console.error("기업별 수주 분석 API 오류:", error);
+    return NextResponse.json(
+      { error: "기업별 수주 분석 조회에 실패했습니다" },
+      { status: 500 }
