+          </p>
+        </div>
+
+        {/* 기간 필터 */}
+        <div className="flex gap-2">
+          <Button
+            variant={period === 30 ? "default" : "outline"}
+            size="sm"
+            onClick={() => setPeriod(30)}
+          >
